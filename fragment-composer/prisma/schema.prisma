generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

/// Minimal User model — only id is needed for FK reference.
/// In shared-db mode, the full User table is created by client migrations.
model User {
  id            String    @id @default(cuid())

  devices       Device[]
  videoProjects VideoProject[]

  @@schema("public")
}

model Device {
  deviceId   String   @id
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  publicKey  String
  deviceName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transferRequestsSent   TransferRequest[] @relation("SentRequests")
  transferRequestsTarget TransferRequest[] @relation("TargetRequests")

  @@schema("public")
}

model VideoProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fragments   Fragment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Fragment {
  id        String   @id @default(cuid())
  name      String
  filePath  String
  size      Int
  duration  Float?
  projectId String
  project   VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@schema("public")
}

enum TransferRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  COMPLETED

  @@schema("public")
}

enum TransferDirection {
  SEND
  RECEIVE

  @@schema("public")
}

model TransferRequest {
  id              String                @id @default(cuid())
  direction       TransferDirection
  status          TransferRequestStatus @default(PENDING)
  sourceDeviceId  String
  sourceDevice    Device                @relation("SentRequests", fields: [sourceDeviceId], references: [deviceId], onDelete: Cascade)
  targetDeviceId  String
  targetDevice    Device                @relation("TargetRequests", fields: [targetDeviceId], references: [deviceId], onDelete: Cascade)
  projectId       String?
  projectName     String?
  fragmentIds     String[]
  fragmentNames   String[]
  message         String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())

  @@schema("public")
}
